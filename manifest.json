{
  "id": "event-rsvps",
  "name": "Event RSVPs",
  "version": "1.1.0",
  "description": "Create org events and collect RSVPs — who's coming, headcount for catering, send reminders to non-responders, export attendee lists.",
  "entrypoint": "index.html",
  "runtime": "static",
  "category": "general",
  "tags": ["events", "rsvp", "attendance", "everyone"],
  "data_access": {
    "reads": ["family.members"],
    "writes": []
  },
  "permissions": {
    "default_audience": "everyone",
    "requires_approval": false
  },
  "storage": "db",
  "row_policies": {
    "events": {
      "kind": "adult_writable"
    },
    "rsvps": {
      "kind": "owner_or_visibility",
      "member_column": "member_id",
      "visibility_column": "visibility",
      "everyone_values": ["everyone"],
      "write_owner_only": true
    },
    "activity": {
      "kind": "owner_only",
      "member_column": "actor_id",
      "adults_bypass": true
    }
  },
  "publishes": ["event.created", "event.cancelled"],
  "alert_on": ["event.created"],
  "nav": { "label": "RSVPs" },
  "resource_limits": {
    "max_db_bytes": 52428800
  },
  "icon": "🎟️",
  "ai_access": {
    "allowed": true,
    "mode": "read",
    "db_exports": ["upcoming_events", "event_rsvp_summary"]
  }
}
